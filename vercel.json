{
  "version": 2,
  "builds": [
    { "src": "api_handler.py", "use": "@vercel/python" },
    { "src": "frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "build" } },
    { "src": "intellitrade-frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "build" } }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api_handler.py" },
    { "source": "/admin", "destination": "/frontend/index.html" },
    { "source": "/admin/(.*)", "destination": "/frontend/$1" },
    { "source": "/login", "destination": "/intellitrade-frontend/index.html" },
    { "source": "/", "destination": "/intellitrade-frontend/index.html" },
    { "source": "/((?!admin|api).*)", "destination": "/intellitrade-frontend/$1" }
  ]
}
